{
  "projectType": "infrastructure",
  "projectName": "fake-gcs-server",
  "projectDescription": "A Google Cloud Storage emulator that can be run as a standalone Docker container or used as a Go testing library.",
  "theme": "aspen",
  "primaryColor": "#ffffff",
  "lightColor": "#74d7ed",
  "darkColor": "#38484e",
  "navigation": {
    "tabs": [
      {
